---
layout: null
---
<?xml version="1.0" encoding="UTF-8"?>
<rss version="2.0"
  xmlns:content="http://purl.org/rss/1.0/modules/content/"
  xmlns:atom="http://www.w3.org/2005/Atom">

<channel>
  <title>{{ site.title | xml_escape }}</title>
  <link>{{ site.url }}</link>
  <description>{{ site.description | xml_escape }}</description>
  <language>{{ site.lang | default: "cs-CZ" }}</language>
  <lastBuildDate>{{ site.time | date_to_rfc822 }}</lastBuildDate>

  <atom:link href="{{ "/export.xml" | absolute_url }}" rel="self" type="application/rss+xml" />

  {% for post in site.posts limit:1300 %}
  <item>
    <title>{{ post.title | xml_escape }}</title>
    <link>{{ post.url | absolute_url }}</link>
    <guid isPermaLink="true">{{ post.url | absolute_url }}</guid>
    <pubDate>{{ post.date | date_to_rfc822 }}</pubDate>

    {% if post.excerpt %}
    <description>{{ post.excerpt | strip_html | xml_escape }}</description>
    {% endif %}

    <content:encoded><![CDATA[
      {{ post.content }}
    ]]></content:encoded>

    {% if post.tags %}
      {% for tag in post.tags %}
      <category>{{ tag | xml_escape }}</category>
      {% endfor %}
    {% endif %}

  </item>
  {% endfor %}

</channel>
</rss>